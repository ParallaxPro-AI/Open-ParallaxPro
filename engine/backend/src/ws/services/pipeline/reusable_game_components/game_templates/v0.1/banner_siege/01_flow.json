{
  "id": "banner_siege_flow",
  "name": "Banner Siege",
  "description": "2-10 player peer-to-peer capture-the-flag. Red vs Blue teams fight across a symmetric arena. Steal the enemy banner, carry it back to your base (while your own banner is home) and score. First team to 3 captures or leader after 5 minutes wins.",
  "start": "boot",
  "multiplayer": {
    "enabled": true,
    "minPlayers": 1,
    "maxPlayers": 10,
    "tickRate": 30,
    "authority": "host",
    "predictLocalPlayer": true,
    "hostPlaysGame": true,
    "remotePlayerPrefab": "player"
  },
  "ui_params": {
    "main_menu": {
      "gameTitle": "BANNER SIEGE",
      "gameSubtitle": "Capture the enemy banner \u00b7 First to 3 wins"
    },
    "pause_menu": {
      "pauseTitle": "PAUSED",
      "pauseHint": "Press <span class=\"pm-kbd\">P</span> to resume",
      "pauseButtons": [
        {
          "action": "resume",
          "label": "Resume",
          "primary": true
        },
        {
          "action": "leave_match",
          "label": "Leave Match",
          "danger": true
        }
      ]
    }
  },
  "states": {
    "boot": {
      "description": "Initialize systems",
      "active_systems": [
        "mp_bridge"
      ],
      "duration": -1,
      "on_enter": [
        "set:boot_frames=0"
      ],
      "on_update": [
        "increment:boot_frames"
      ],
      "transitions": [
        {
          "when": "boot_frames>=2",
          "goto": "main_menu"
        }
      ]
    },
    "main_menu": {
      "description": "Title screen",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "mp:leave_lobby",
        "show_ui:main_menu",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:main_menu",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:main_menu:start_game",
          "goto": "lobby_browser"
        }
      ]
    },
    "lobby_browser": {
      "description": "Browse open lobbies or host a new one",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_browser",
        "show_cursor",
        "mp:refresh_lobbies"
      ],
      "on_exit": [
        "hide_ui:lobby_browser",
        "hide_ui:lobby_host_config"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_lobby",
          "goto": "lobby_room"
        },
        {
          "when": "mp_event:back_to_menu",
          "goto": "main_menu"
        }
      ]
    },
    "lobby_room": {
      "description": "Pre-match lobby with roster, chat, voice",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_room",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:lobby_room"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_game",
          "goto": "gameplay",
          "actions": [
            "emit:game.match_started"
          ]
        },
        {
          "when": "mp_event:phase_browsing",
          "goto": "lobby_browser"
        },
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        }
      ]
    },
    "gameplay": {
      "description": "Match in progress",
      "active_systems": [
        "mp_bridge",
        "banner_siege_game"
      ],
      "start": "playing",
      "on_enter": [
        "show_ui:hud/ping",
        "hide_cursor",
        "show_ui:hud/scoreboard",
        "show_ui:hud/banner_siege_hud",
        "show_ui:hud/health",
        "show_ui:hud/ammo",
        "show_ui:hud/crosshair"
      ],
      "on_exit": [
        "hide_ui:hud/ping",
        "hide_ui:hud/scoreboard",
        "hide_ui:hud/banner_siege_hud",
        "hide_ui:hud/health",
        "hide_ui:hud/ammo",
        "hide_ui:hud/crosshair",
        "hide_ui:pause_menu"
      ],
      "substates": {
        "playing": {
          "active_behaviors": [
            "fps_camera",
            "fps_movement",
            "fps_combat",
            "player_health"
          ],
          "on_enter": [
            "hide_cursor"
          ],
          "transitions": [
            {
              "when": "keyboard:pause",
              "goto": "paused"
            },
            {
              "when": "game_event:player_died",
              "goto": "dead"
            }
          ]
        },
        "dead": {
          "active_behaviors": [
            "fps_camera",
            "player_health"
          ],
          "transitions": [
            {
              "when": "game_event:player_respawned",
              "goto": "playing"
            }
          ]
        },
        "paused": {
          "active_behaviors": [],
          "on_enter": [
            "show_ui:pause_menu",
            "show_cursor"
          ],
          "on_exit": [
            "hide_ui:pause_menu"
          ],
          "transitions": [
            {
              "when": "keyboard:resume",
              "goto": "playing"
            },
            {
              "when": "ui_event:pause_menu:resume",
              "goto": "playing"
            }
          ]
        }
      },
      "transitions": [
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        },
        {
          "when": "game_event:match_ended",
          "goto": "game_over"
        },
        {
          "when": "ui_event:pause_menu:leave_match",
          "goto": "main_menu"
        }
      ]
    },
    "game_over": {
      "description": "Match summary",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:game_over",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "lobby_room"
        },
        {
          "when": "ui_event:game_over:main_menu",
          "goto": "main_menu"
        }
      ]
    }
  }
}