{
  "id": "rhythm_runner_flow",
  "name": "Rhythm Runner",
  "start": "boot",
  "ui_params": {
    "main_menu": { "gameTitle": "RHYTHM RUNNER", "gameSubtitle": "Neon Beat Course" }
  },
  "states": {
    "boot": {
      "description": "Initialize",
      "duration": -1,
      "on_enter": ["set:boot_frames=0"],
      "on_update": ["increment:boot_frames"],
      "transitions": [{ "when": "boot_frames>=2", "goto": "main_menu" }]
    },
    "main_menu": {
      "description": "Title screen",
      "on_enter": ["show_ui:main_menu", "show_cursor"],
      "on_exit": ["hide_ui:main_menu", "hide_cursor"],
      "transitions": [{ "when": "ui_event:main_menu:start_game", "goto": "countdown" }]
    },
    "countdown": {
      "description": "3-2-1 countdown before run",
      "duration": 4,
      "active_behaviors": ["camera_surf"],
      "on_enter": [
        "emit:game.game_ready",
        "emit:game.race_start",
        "show_ui:hud/course_hud",
        "show_ui:hud/health",
        "show_ui:hud/score",
        "show_ui:hud/race_countdown",
        "play_sound:/assets/kenney/audio/interface_sounds/pepSound1.ogg"
      ],
      "transitions": [{
        "when": "timer_expired",
        "goto": "playing",
        "actions": [
          "emit:game.race_started",
          "play_sound:/assets/kenney/audio/voiceover_pack/go.ogg"
        ]
      }]
    },
    "playing": {
      "description": "Active rhythm running on the neon course",
      "active_systems": ["scoring"],
      "active_behaviors": [
        "camera_surf",
        "surf_runner",
        "course_progress",
        "player_health",
        "spinning_obstacle",
        "moving_platform"
      ],
      "on_enter": ["hide_ui:hud/race_countdown"],
      "transitions": [
        {
          "when": "game_event:race_finished",
          "goto": "game_over",
          "actions": [
            "play_sound:/assets/kenney/audio/interface_sounds/confirmation_004.ogg"
          ]
        },
        {
          "when": "game_event:player_died",
          "goto": "game_over",
          "actions": [
            "play_sound:/assets/kenney/audio/impact_sounds/impactPlate_heavy_004.ogg"
          ]
        }
      ]
    },
    "game_over": {
      "description": "Run complete or player eliminated",
      "active_behaviors": ["camera_surf"],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor",
        "play_sound:/assets/kenney/audio/voiceover_pack/game_over.ogg"
      ],
      "on_exit": [
        "hide_ui:game_over",
        "hide_ui:hud/course_hud",
        "hide_ui:hud/health",
        "hide_ui:hud/score",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "countdown",
          "actions": [
            "emit:game.restart_game",
            "set:score=0"
          ]
        },
        { "when": "ui_event:game_over:main_menu", "goto": "main_menu" }
      ]
    }
  }
}
