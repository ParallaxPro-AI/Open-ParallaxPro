{
  "id": "party_bash_flow",
  "name": "Party Bash",
  "start": "boot",
  "ui_params": {
    "main_menu": {
      "gameTitle": "PARTY BASH",
      "gameSubtitle": "Minigame Madness"
    }
  },
  "states": {
    "boot": {
      "description": "Initialize",
      "duration": -1,
      "active_systems": [
        "party_engine"
      ],
      "on_enter": [
        "set:boot_frames=0"
      ],
      "on_update": [
        "increment:boot_frames"
      ],
      "transitions": [
        {
          "when": "boot_frames>=2",
          "goto": "main_menu"
        }
      ]
    },
    "main_menu": {
      "description": "Title screen",
      "on_enter": [
        "show_ui:main_menu",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:main_menu",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:main_menu:start_game",
          "goto": "playing",
          "actions": [
            "emit:game.game_ready"
          ]
        }
      ]
    },
    "playing": {
      "description": "Party game \u2014 rotating minigames across 5 rounds",
      "active_systems": [
        "party_engine"
      ],
      "active_behaviors": [
        "party_player",
        "camera_party"
      ],
      "on_enter": [
        "show_ui:hud/party_hud",
        "hide_cursor",
        "play_sound:/assets/kenney/audio/interface_sounds/confirmation_002.ogg"
      ],
      "transitions": [
        {
          "when": "game_event:game_over",
          "goto": "game_over"
        },
        {
          "when": "game_event:game_won",
          "goto": "game_over"
        }
      ]
    },
    "game_over": {
      "description": "Final results",
      "active_behaviors": [
        "camera_party"
      ],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:game_over",
        "hide_ui:hud/party_hud",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "playing",
          "actions": [
            "emit:game.restart_game",
            "emit:game.game_ready"
          ]
        },
        {
          "when": "ui_event:game_over:main_menu",
          "goto": "main_menu"
        }
      ]
    }
  }
}