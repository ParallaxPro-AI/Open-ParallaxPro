{
  "id": "jelly_jam_flow",
  "name": "Jelly Jam",
  "description": "1-12 player peer-to-peer party-elimination minigame bracket. Three rounds of obstacle-course sprint-races; the bottom half is bumped out each round; last jelly bouncing wins. Spinning beams, dive-roll dodges, and a bouncy chase camera keep it chaotic. Single-player works without changes — you just get an unopposed track.",
  "start": "boot",
  "multiplayer": {
    "enabled": true,
    "minPlayers": 1,
    "maxPlayers": 12,
    "tickRate": 30,
    "authority": "host",
    "predictLocalPlayer": true,
    "hostPlaysGame": true,
    "remotePlayerPrefab": "player",
    "allowJoinInProgress": false
  },
  "ui_params": {
    "main_menu": {
      "gameTitle": "JELLY JAM",
      "gameSubtitle": "Three rounds. Bumped or crowned."
    },
    "pause_menu": {
      "pauseTitle": "PAUSED",
      "pauseHint": "Press <span class=\"pm-kbd\">P</span> to resume",
      "pauseButtons": [
        {
          "action": "resume",
          "label": "Resume",
          "primary": true
        },
        {
          "action": "leave_match",
          "label": "Leave Match",
          "danger": true
        }
      ]
    }
  },
  "states": {
    "boot": {
      "description": "Initialize systems",
      "active_systems": [
        "mp_bridge"
      ],
      "duration": -1,
      "on_enter": [
        "set:boot_frames=0"
      ],
      "on_update": [
        "increment:boot_frames"
      ],
      "transitions": [
        {
          "when": "boot_frames>=2",
          "goto": "main_menu"
        }
      ]
    },
    "main_menu": {
      "description": "Title screen",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "mp:leave_lobby",
        "hide_ui:hud/voice_chat",
        "hide_ui:hud/text_chat",
        "show_ui:main_menu",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:main_menu",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:main_menu:start_game",
          "goto": "lobby_browser"
        }
      ]
    },
    "lobby_browser": {
      "description": "Browse open lobbies or host a new one",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_browser",
        "show_cursor",
        "mp:refresh_lobbies"
      ],
      "on_exit": [
        "hide_ui:lobby_browser",
        "hide_ui:lobby_host_config"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_lobby",
          "goto": "lobby_room"
        },
        {
          "when": "mp_event:back_to_menu",
          "goto": "main_menu"
        }
      ]
    },
    "lobby_room": {
      "description": "Pre-match lobby with roster, chat, voice",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_room",
        "show_ui:hud/voice_chat",
        "show_ui:hud/text_chat",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:lobby_room"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_game",
          "goto": "gameplay",
          "actions": [
            "emit:game.match_started"
          ]
        },
        {
          "when": "mp_event:phase_browsing",
          "goto": "lobby_browser"
        },
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        }
      ]
    },
    "gameplay": {
      "description": "Match in progress",
      "active_systems": [
        "mp_bridge",
        "jelly_jam_game"
      ],
      "start": "playing",
      "on_enter": [
        "show_ui:hud/voice_chat",
        "show_ui:hud/text_chat",
        "show_ui:hud/ping",
        "show_ui:hud/jelly_jam_hud",
        "hide_cursor"
      ],
      "on_exit": [
        "hide_ui:hud/ping",
        "hide_ui:hud/jelly_jam_hud",
        "hide_ui:pause_menu"
      ],
      "substates": {
        "playing": {
          "active_behaviors": [
            "jelly_player",
            "camera_party_chase"
          ],
          "transitions": [
            {
              "when": "keyboard:pause",
              "goto": "paused"
            }
          ]
        },
        "paused": {
          "active_behaviors": [],
          "on_enter": [
            "show_ui:pause_menu",
            "show_cursor"
          ],
          "on_exit": [
            "hide_ui:pause_menu",
            "hide_cursor"
          ],
          "transitions": [
            {
              "when": "keyboard:resume",
              "goto": "playing"
            },
            {
              "when": "ui_event:pause_menu:resume",
              "goto": "playing"
            }
          ]
        }
      },
      "transitions": [
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        },
        {
          "when": "game_event:match_ended",
          "goto": "game_over"
        },
        {
          "when": "ui_event:pause_menu:leave_match",
          "goto": "main_menu"
        }
      ]
    },
    "game_over": {
      "description": "Match summary",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:game_over",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "lobby_room"
        },
        {
          "when": "ui_event:game_over:main_menu",
          "goto": "main_menu"
        }
      ]
    }
  },
  "controls": {
    "preset": "platformer",
    "movement": {
      "type": "wasd+arrows",
      "sprint": "ShiftLeft",
      "jump": "Space"
    },
    "look": {
      "type": "mouseDelta",
      "sensitivity": 0.8
    },
    "fire": {
      "secondary": "MouseRight",
      "secondaryLabel": "Aim",
      "holdSecondary": true
    },
    "actions": [
      {
        "key": "KeyQ",
        "label": "Bounce"
      }
    ],
    "viewport": {
      "tap": "click"
    }
  }
}
