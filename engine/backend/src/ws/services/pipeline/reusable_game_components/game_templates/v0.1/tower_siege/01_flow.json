{
  "id": "tower_siege_flow",
  "name": "Tower Siege",
  "start": "boot",
  "ui_params": {
    "main_menu": { "gameTitle": "TOWER SIEGE", "gameSubtitle": "Tower Defense" }
  },
  "states": {
    "boot": {
      "description": "Initialize",
      "duration": -1,
      "active_systems": ["td_engine"],
      "on_enter": ["set:boot_frames=0"],
      "on_update": ["increment:boot_frames"],
      "transitions": [{ "when": "boot_frames>=2", "goto": "main_menu" }]
    },
    "main_menu": {
      "description": "Title screen",
      "on_enter": ["show_ui:main_menu", "show_cursor"],
      "on_exit": ["hide_ui:main_menu", "hide_cursor"],
      "transitions": [{ "when": "ui_event:main_menu:start_game", "goto": "playing" }]
    },
    "playing": {
      "description": "Tower defense gameplay — place towers, defeat waves",
      "active_systems": ["td_engine"],
      "active_behaviors": ["camera_td"],
      "on_enter": [
        "emit:game.game_ready",
        "show_ui:hud/td_hud",
        "play_sound:/assets/kenney/audio/interface_sounds/confirmation_002.ogg"
      ],
      "transitions": [
        {
          "when": "game_event:game_over",
          "goto": "game_over",
          "actions": ["play_sound:/assets/kenney/audio/voiceover_pack/game_over.ogg"]
        },
        {
          "when": "game_event:game_won",
          "goto": "game_over",
          "actions": ["play_sound:/assets/kenney/audio/voiceover_pack/congratulations.ogg"]
        }
      ]
    },
    "game_over": {
      "description": "Victory or defeat results",
      "active_behaviors": ["camera_td"],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:game_over",
        "hide_ui:hud/td_hud",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "playing",
          "actions": ["emit:game.restart_game"]
        },
        { "when": "ui_event:game_over:main_menu", "goto": "main_menu" }
      ]
    }
  }
}
