{
  "id": "buccaneer_bay_flow",
  "name": "Buccaneer Bay",
  "description": "1-6 captain peer-to-peer pirate sea adventure. Sail your galleon across an open ocean dotted with islands, hunt floating treasure, broadside enemy ships, and survive sea monsters. First captain to 200 gold or highest plunder when sunset falls wins the bay.",
  "start": "boot",
  "multiplayer": {
    "enabled": true,
    "minPlayers": 1,
    "maxPlayers": 6,
    "tickRate": 30,
    "authority": "host",
    "predictLocalPlayer": true,
    "hostPlaysGame": true,
    "remotePlayerPrefab": "player"
  },
  "ui_params": {
    "main_menu": {
      "gameTitle": "BUCCANEER BAY",
      "gameSubtitle": "A captain's life for thee"
    },
    "pause_menu": {
      "pauseTitle": "ANCHORED",
      "pauseHint": "Press <span class=\"pm-kbd\">P</span> to weigh anchor",
      "pauseButtons": [
        {
          "action": "resume",
          "label": "Set Sail",
          "primary": true
        },
        {
          "action": "leave_match",
          "label": "Abandon Ship",
          "danger": true
        }
      ]
    }
  },
  "states": {
    "boot": {
      "description": "Initialize systems",
      "active_systems": [
        "mp_bridge"
      ],
      "duration": -1,
      "on_enter": [
        "set:boot_frames=0"
      ],
      "on_update": [
        "increment:boot_frames"
      ],
      "transitions": [
        {
          "when": "boot_frames>=2",
          "goto": "main_menu"
        }
      ]
    },
    "main_menu": {
      "description": "Title screen",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "mp:leave_lobby",
        "show_ui:main_menu",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:main_menu",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:main_menu:start_game",
          "goto": "lobby_browser"
        }
      ]
    },
    "lobby_browser": {
      "description": "Browse open lobbies or host a new crew",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_browser",
        "show_cursor",
        "mp:refresh_lobbies"
      ],
      "on_exit": [
        "hide_ui:lobby_browser",
        "hide_ui:lobby_host_config"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_lobby",
          "goto": "lobby_room"
        },
        {
          "when": "mp_event:back_to_menu",
          "goto": "main_menu"
        }
      ]
    },
    "lobby_room": {
      "description": "Pre-voyage lobby \u2014 roster, chat, voice",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_room",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:lobby_room"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_game",
          "goto": "gameplay",
          "actions": [
            "emit:game.match_started"
          ]
        },
        {
          "when": "mp_event:phase_browsing",
          "goto": "lobby_browser"
        },
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        }
      ]
    },
    "gameplay": {
      "description": "Voyage in progress",
      "active_systems": [
        "mp_bridge",
        "pirate_voyage",
        "ocean_atmosphere",
        "entity_health_bars"
      ],
      "start": "sailing",
      "on_enter": [
        "show_ui:hud/ping",
        "hide_cursor",
        "show_ui:hud/scoreboard",
        "show_ui:hud/gold_purse",
        "show_ui:hud/ship_status",
        "show_ui:hud/spyglass_compass",
        "show_ui:hud/crosshair",
        "show_ui:hud/entity_health_bars"
      ],
      "on_exit": [
        "hide_ui:hud/ping",
        "hide_ui:hud/scoreboard",
        "hide_ui:hud/gold_purse",
        "hide_ui:hud/ship_status",
        "hide_ui:hud/spyglass_compass",
        "hide_ui:hud/crosshair",
        "hide_ui:hud/entity_health_bars",
        "hide_ui:pause_menu"
      ],
      "substates": {
        "sailing": {
          "active_behaviors": [
            "ship_sail",
            "cannon_broadside",
            "camera_galleon",
            "ship_health",
            "sea_monster",
            "ghost_ship"
          ],
          "on_enter": [
            "hide_cursor"
          ],
          "transitions": [
            {
              "when": "keyboard:pause",
              "goto": "paused"
            }
          ]
        },
        "paused": {
          "active_behaviors": [],
          "on_enter": [
            "show_ui:pause_menu",
            "show_cursor"
          ],
          "on_exit": [
            "hide_ui:pause_menu"
          ],
          "transitions": [
            {
              "when": "keyboard:resume",
              "goto": "sailing"
            },
            {
              "when": "ui_event:pause_menu:resume",
              "goto": "sailing"
            }
          ]
        }
      },
      "transitions": [
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        },
        {
          "when": "game_event:match_ended",
          "goto": "game_over"
        },
        {
          "when": "ui_event:pause_menu:leave_match",
          "goto": "main_menu"
        }
      ]
    },
    "game_over": {
      "description": "Voyage summary",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:game_over",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "lobby_room"
        },
        {
          "when": "ui_event:game_over:main_menu",
          "goto": "main_menu"
        }
      ]
    }
  }
}