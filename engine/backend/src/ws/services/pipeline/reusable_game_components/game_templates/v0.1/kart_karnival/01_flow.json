{
  "id": "kart_karnival_flow",
  "name": "Kart Karnival",
  "description": "1-8 player mario-kart style multiplayer racer. Drift around a circuit, grab item boxes for boost / missile / banana / shield / bolt power-ups, complete 3 laps to win. Auto-balanced FFA grid, place-based ranking, full lap timer.",
  "start": "boot",
  "multiplayer": {
    "enabled": true,
    "minPlayers": 1,
    "maxPlayers": 8,
    "tickRate": 30,
    "authority": "host",
    "predictLocalPlayer": true,
    "hostPlaysGame": true,
    "remotePlayerPrefab": "player"
  },
  "ui_params": {
    "main_menu": {
      "gameTitle": "KART KARNIVAL",
      "gameSubtitle": "Drift. Drop. Win."
    },
    "pause_menu": {
      "pauseTitle": "PIT BOX",
      "pauseHint": "Press <span class=\"pm-kbd\">P</span> to roll out",
      "pauseButtons": [
        {
          "action": "resume",
          "label": "Back to Track",
          "primary": true
        },
        {
          "action": "leave_match",
          "label": "Forfeit",
          "danger": true
        }
      ]
    }
  },
  "states": {
    "boot": {
      "description": "Initialize systems",
      "active_systems": [
        "mp_bridge"
      ],
      "duration": -1,
      "on_enter": [
        "set:boot_frames=0"
      ],
      "on_update": [
        "increment:boot_frames"
      ],
      "transitions": [
        {
          "when": "boot_frames>=2",
          "goto": "main_menu"
        }
      ]
    },
    "main_menu": {
      "description": "Title screen",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "mp:leave_lobby",
        "hide_ui:hud/voice_chat",
        "hide_ui:hud/text_chat",
        "show_ui:main_menu",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:main_menu",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:main_menu:start_game",
          "goto": "lobby_browser"
        }
      ]
    },
    "lobby_browser": {
      "description": "Browse open races or host a new one",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_browser",
        "show_cursor",
        "mp:refresh_lobbies"
      ],
      "on_exit": [
        "hide_ui:lobby_browser",
        "hide_ui:lobby_host_config"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_lobby",
          "goto": "lobby_room"
        },
        {
          "when": "mp_event:back_to_menu",
          "goto": "main_menu"
        }
      ]
    },
    "lobby_room": {
      "description": "Pre-grid lobby — roster, chat, voice",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_room",
        "show_ui:hud/voice_chat",
        "show_ui:hud/text_chat",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:lobby_room"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_game",
          "goto": "gameplay",
          "actions": [
            "emit:game.match_started"
          ]
        },
        {
          "when": "mp_event:phase_browsing",
          "goto": "lobby_browser"
        },
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        }
      ]
    },
    "gameplay": {
      "description": "Race in progress",
      "active_systems": [
        "mp_bridge",
        "kart_race"
      ],
      "start": "racing",
      "on_enter": [
        "show_ui:hud/voice_chat",
        "show_ui:hud/text_chat",
        "show_ui:hud/ping",
        "hide_cursor",
        "show_ui:hud/scoreboard",
        "show_ui:hud/speedometer",
        "show_ui:hud/race_position",
        "show_ui:hud/powerup_inventory",
        "show_ui:hud/lap_timer"
      ],
      "on_exit": [
        "hide_ui:hud/ping",
        "hide_ui:hud/scoreboard",
        "hide_ui:hud/speedometer",
        "hide_ui:hud/race_position",
        "hide_ui:hud/powerup_inventory",
        "hide_ui:hud/lap_timer",
        "hide_ui:pause_menu"
      ],
      "substates": {
        "racing": {
          "active_behaviors": [
            "kart_drive",
            "camera_kart"
          ],
          "on_enter": [
            "hide_cursor"
          ],
          "transitions": [
            {
              "when": "keyboard:pause",
              "goto": "paused"
            }
          ]
        },
        "paused": {
          "active_behaviors": [],
          "on_enter": [
            "show_ui:pause_menu",
            "show_cursor"
          ],
          "on_exit": [
            "hide_ui:pause_menu"
          ],
          "transitions": [
            {
              "when": "keyboard:resume",
              "goto": "racing"
            },
            {
              "when": "ui_event:pause_menu:resume",
              "goto": "racing"
            }
          ]
        }
      },
      "transitions": [
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        },
        {
          "when": "game_event:match_ended",
          "goto": "game_over"
        },
        {
          "when": "ui_event:pause_menu:leave_match",
          "goto": "main_menu"
        }
      ]
    },
    "game_over": {
      "description": "Race summary",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:game_over",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "lobby_room",
          "actions": [
            "restart"
          ]
        },
        {
          "when": "ui_event:game_over:main_menu",
          "goto": "main_menu"
        }
      ]
    }
  },
  "controls": {
    "preset": "racer",
    "movement": {
      "type": "wasd+arrows"
    },
    "look": {
      "type": "none"
    },
    "actions": [
      {
        "key": "Space",
        "label": "Drift",
        "hold": true
      },
      {
        "key": "KeyE",
        "label": "Item"
      }
    ],
    "viewport": {
      "tap": "none"
    }
  }
}
