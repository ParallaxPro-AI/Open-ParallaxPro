{
  "systems": {
    "entity_health_bars": {
      "description": "Classic MOBA HP bars. Values match the per-behavior _health params in 02_entities.json so percentages stay accurate: hero 500, minions 200, towers 2000, nexus 3000.",
      "script": "gameplay/entity_health_bars.ts",
      "params": {
        "allyTags": ["player", "hero"],
        "enemyTags": ["minion", "tower", "nexus", "structure"],
        "showAllies": true,
        "defaultMax": 200,
        "hpOverrides": {
          "blue_nexus": 3000,
          "red_nexus": 3000,
          "nexus": 3000,
          "blue_tower": 2000,
          "red_tower": 2000,
          "tower": 2000,
          "hero": 500,
          "blue_minion": 200,
          "red_minion": 200,
          "minion": 200
        },
        "heightAbove": 2.5
      }
    },
    "minion_spawner": {
      "description": "Spawns minion waves for both teams periodically",
      "script": "gameplay/minion_spawner.ts",
      "params": {
        "spawnInterval": 25,
        "firstWaveDelay": 5,
        "waveSize": 3
      }
    },
    "gold_system": {
      "description": "Tracks player gold and kill count",
      "script": "gameplay/gold_system.ts",
      "params": {
        "passiveRate": 2
      }
    }
  }
}
