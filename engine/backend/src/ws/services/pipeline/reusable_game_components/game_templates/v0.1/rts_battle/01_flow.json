{
  "id": "rts_battle_flow",
  "name": "RTS Battle",
  "start": "boot",
  "ui_params": {
    "main_menu": {
      "gameTitle": "IRON COMMAND",
      "gameSubtitle": "Galactic Warfare"
    }
  },
  "states": {
    "boot": {
      "description": "Initialize RTS systems",
      "active_systems": [
        "resource_system",
        "production_system"
      ],
      "duration": -1,
      "on_enter": [
        "set:boot_frames=0"
      ],
      "on_update": [
        "increment:boot_frames"
      ],
      "transitions": [
        {
          "when": "boot_frames>=2",
          "goto": "main_menu"
        }
      ]
    },
    "main_menu": {
      "description": "Title screen",
      "on_enter": [
        "show_ui:main_menu",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:main_menu"
      ],
      "transitions": [
        {
          "when": "ui_event:main_menu:start_game",
          "goto": "gameplay"
        }
      ]
    },
    "gameplay": {
      "description": "Real-time strategy gameplay",
      "start": "battle",
      "on_enter": [
        "emit:game.game_ready"
      ],
      "on_exit": [],
      "substates": {
        "battle": {
          "description": "Active RTS battle \u2014 build base, gather resources, train army, destroy enemy",
          "active_systems": [
            "resource_system",
            "production_system",
            "combat_system",
            "enemy_commander"
          ],
          "active_behaviors": [
            "rts_camera",
            "worker_ai",
            "unit_combat",
            "ranged_combat",
            "medic_ai",
            "turret_defense",
            "enemy_swarm_ai",
            "enemy_assault_ai",
            "enemy_air_ai",
            "enemy_worker_ai"
          ],
          "on_enter": [
            "show_ui:hud/resources",
            "show_cursor",
            "show_ui:hud/minimap",
            "show_ui:hud/unit_panel",
            "show_ui:hud/command_panel",
            "show_ui:hud/selection",
            "show_ui:hud/supply",
            "emit:game.battle_start",
            "play_sound:/assets/kenney/audio/sci_fi_sounds/spaceEngine_000.ogg"
          ],
          "on_exit": [
            "hide_ui:hud/resources",
            "hide_ui:hud/minimap",
            "hide_ui:hud/unit_panel",
            "hide_ui:hud/command_panel",
            "hide_ui:hud/selection",
            "hide_ui:hud/supply"
          ],
          "transitions": [
            {
              "when": "game_event:victory",
              "goto": "victory"
            },
            {
              "when": "game_event:defeat",
              "goto": "defeat"
            }
          ]
        },
        "victory": {
          "description": "Player destroyed enemy base",
          "active_systems": [
            "resource_system"
          ],
          "active_behaviors": [
            "rts_camera"
          ],
          "on_enter": [
            "show_ui:game_over",
            "show_cursor",
            "play_sound:/assets/kenney/audio/digital_audio/powerUp12.ogg"
          ],
          "on_exit": [
            "hide_ui:game_over",
            "emit:game.game_ready"
          ],
          "transitions": [
            {
              "when": "ui_event:game_over:play_again",
              "goto": "battle"
            }
          ]
        },
        "defeat": {
          "description": "Player base destroyed",
          "active_systems": [
            "resource_system"
          ],
          "active_behaviors": [
            "rts_camera"
          ],
          "on_enter": [
            "show_ui:game_over",
            "show_cursor",
            "play_sound:/assets/kenney/audio/sci_fi_sounds/lowFrequency_explosion_001.ogg"
          ],
          "on_exit": [
            "hide_ui:game_over",
            "emit:game.game_ready"
          ],
          "transitions": [
            {
              "when": "ui_event:game_over:play_again",
              "goto": "battle"
            }
          ]
        }
      },
      "transitions": [
        {
          "when": "ui_event:game_over:main_menu",
          "goto": "main_menu"
        }
      ]
    }
  }
}