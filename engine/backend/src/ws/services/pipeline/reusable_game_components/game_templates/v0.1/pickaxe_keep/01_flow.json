{
  "id": "pickaxe_keep_flow",
  "name": "Pickaxe Keep",
  "description": "1-4 player peer-to-peer 2.5D sidescroll mining + crafting + survival sandbox. Dig dirt → stone → ore, craft better pickaxes, plant torches, and survive zombie nights. Host generates the opening world; everyone shares it. Single-player works without a friend — just host alone.",
  "start": "boot",
  "multiplayer": {
    "enabled": true,
    "minPlayers": 1,
    "maxPlayers": 4,
    "tickRate": 30,
    "authority": "host",
    "predictLocalPlayer": true,
    "hostPlaysGame": true,
    "remotePlayerPrefab": "player",
    "allowJoinInProgress": true
  },
  "ui_params": {
    "main_menu": {
      "gameTitle": "PICKAXE KEEP",
      "gameSubtitle": "Mine. Build. Survive the night."
    },
    "pause_menu": {
      "pauseTitle": "PAUSED",
      "pauseHint": "Press <span class=\"pm-kbd\">P</span> to resume",
      "pauseButtons": [
        {
          "action": "resume",
          "label": "Resume",
          "primary": true
        },
        {
          "action": "leave_match",
          "label": "Leave World",
          "danger": true
        }
      ]
    }
  },
  "states": {
    "boot": {
      "description": "Initialize systems",
      "active_systems": [
        "mp_bridge"
      ],
      "duration": -1,
      "on_enter": [
        "set:boot_frames=0"
      ],
      "on_update": [
        "increment:boot_frames"
      ],
      "transitions": [
        {
          "when": "boot_frames>=2",
          "goto": "main_menu"
        }
      ]
    },
    "main_menu": {
      "description": "Title screen",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "mp:leave_lobby",
        "hide_ui:hud/voice_chat",
        "hide_ui:hud/text_chat",
        "show_ui:main_menu",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:main_menu"
      ],
      "transitions": [
        {
          "when": "ui_event:main_menu:start_game",
          "goto": "lobby_browser"
        }
      ]
    },
    "lobby_browser": {
      "description": "Browse open lobbies or host a new one",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_browser",
        "show_cursor",
        "mp:refresh_lobbies"
      ],
      "on_exit": [
        "hide_ui:lobby_browser",
        "hide_ui:lobby_host_config"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_lobby",
          "goto": "lobby_room"
        },
        {
          "when": "mp_event:back_to_menu",
          "goto": "main_menu"
        }
      ]
    },
    "lobby_room": {
      "description": "Pre-match lobby with roster, chat, voice",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_room",
        "show_ui:hud/voice_chat",
        "show_ui:hud/text_chat",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:lobby_room"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_game",
          "goto": "gameplay",
          "actions": [
            "emit:game.match_started"
          ]
        },
        {
          "when": "mp_event:phase_browsing",
          "goto": "lobby_browser"
        },
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        }
      ]
    },
    "gameplay": {
      "description": "World loaded — dig in",
      "active_systems": [
        "mp_bridge",
        "pickaxe_keep_game"
      ],
      "start": "playing",
      "on_enter": [
        "show_ui:hud/voice_chat",
        "show_ui:hud/text_chat",
        "show_ui:hud/ping",
        "show_ui:hud/pickaxe_stats",
        "show_ui:hud/pickaxe_hotbar",
        "show_ui:hud/pickaxe_inventory",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:hud/ping",
        "hide_ui:hud/pickaxe_stats",
        "hide_ui:hud/pickaxe_hotbar",
        "hide_ui:hud/pickaxe_inventory",
        "hide_ui:pause_menu"
      ],
      "substates": {
        "playing": {
          "active_behaviors": [
            "sidescroll_platformer",
            "camera_sidescroll",
            "block_interactor"
          ],
          "transitions": [
            {
              "when": "keyboard:pause",
              "goto": "paused"
            }
          ]
        },
        "paused": {
          "active_behaviors": [],
          "on_enter": [
            "show_ui:pause_menu"
          ],
          "on_exit": [
            "hide_ui:pause_menu"
          ],
          "transitions": [
            {
              "when": "keyboard:resume",
              "goto": "playing"
            },
            {
              "when": "ui_event:pause_menu:resume",
              "goto": "playing"
            }
          ]
        }
      },
      "transitions": [
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        },
        {
          "when": "game_event:match_ended",
          "goto": "game_over"
        },
        {
          "when": "ui_event:pause_menu:leave_match",
          "goto": "main_menu"
        }
      ]
    },
    "game_over": {
      "description": "Match summary",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:game_over"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "lobby_room",
          "actions": [
            "restart"
          ]
        },
        {
          "when": "ui_event:game_over:main_menu",
          "goto": "main_menu"
        }
      ]
    }
  },
  "controls": {
    "preset": "platformer",
    "movement": {
      "type": "horizontal",
      "jump": "Space"
    },
    "look": {
      "type": "none"
    },
    "fire": {
      "primary": "MouseLeft",
      "secondary": "MouseRight",
      "label": "Place",
      "secondaryLabel": "Mine"
    },
    "actions": [
      {
        "key": "KeyE",
        "label": "Use"
      }
    ],
    "hudKeys": [
      "Digit1",
      "Digit2",
      "Digit3",
      "Digit4",
      "Digit5"
    ],
    "viewport": {
      "tap": "click"
    }
  }
}
