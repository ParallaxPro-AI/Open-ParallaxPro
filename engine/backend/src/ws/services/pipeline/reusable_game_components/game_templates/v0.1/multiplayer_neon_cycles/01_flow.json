{
  "id": "multiplayer_neon_cycles_flow",
  "name": "Neon Cycles",
  "description": "Top-down arcade light-bike combat for 2-8 players. Each bike leaves a glowing wall behind it; cross any wall (yours, theirs, or the arena edge) and you crash. Last bike standing wins the round; first to 3 round wins takes the match.",
  "start": "boot",
  "multiplayer": {
    "enabled": true,
    "minPlayers": 2,
    "maxPlayers": 8,
    "tickRate": 30,
    "authority": "host",
    "predictLocalPlayer": true,
    "hostPlaysGame": true,
    "remotePlayerPrefab": "bike_player"
  },
  "ui_params": {
    "main_menu": {
      "gameTitle": "NEON CYCLES",
      "gameSubtitle": "Trap. Slice. Survive."
    }
  },
  "states": {
    "boot": {
      "description": "Initialize systems",
      "active_systems": [
        "mp_bridge"
      ],
      "duration": -1,
      "on_enter": [
        "set:boot_frames=0"
      ],
      "on_update": [
        "increment:boot_frames"
      ],
      "transitions": [
        {
          "when": "boot_frames>=2",
          "goto": "main_menu"
        }
      ]
    },
    "main_menu": {
      "description": "Title screen",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "mp:leave_lobby",
        "hide_ui:hud/voice_chat",
        "show_ui:main_menu",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:main_menu",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:main_menu:start_game",
          "goto": "lobby_browser"
        }
      ]
    },
    "lobby_browser": {
      "description": "Browse open lobbies or host a new one",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_browser",
        "show_cursor",
        "mp:refresh_lobbies"
      ],
      "on_exit": [
        "hide_ui:lobby_browser",
        "hide_ui:lobby_host_config"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_lobby",
          "goto": "lobby_room"
        },
        {
          "when": "mp_event:back_to_menu",
          "goto": "main_menu"
        }
      ]
    },
    "lobby_room": {
      "description": "Pre-match lobby with roster, chat, voice",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:lobby_room",
        "show_ui:hud/voice_chat",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:lobby_room"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_in_game",
          "goto": "gameplay",
          "actions": [
            "emit:game.match_started"
          ]
        },
        {
          "when": "mp_event:phase_browsing",
          "goto": "lobby_browser"
        },
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        }
      ]
    },
    "gameplay": {
      "description": "Match in progress \u2014 bikes ride, trails grow, last alive wins each round.",
      "active_systems": [
        "mp_bridge",
        "neon_cycles_match"
      ],
      "active_behaviors": [
        "bike_player_control",
        "bike_chase_camera",
        "light_trail_emitter"
      ],
      "on_enter": [
        "show_ui:hud/voice_chat",
        "show_ui:hud/ping",
        "show_ui:hud/scoreboard",
        "show_ui:hud/neon_round_status",
        "show_ui:hud/neon_boost_meter",
        "hide_cursor"
      ],
      "on_exit": [
        "hide_ui:hud/ping",
        "hide_ui:hud/scoreboard",
        "hide_ui:hud/neon_round_status",
        "hide_ui:hud/neon_boost_meter"
      ],
      "transitions": [
        {
          "when": "mp_event:phase_disconnected",
          "goto": "main_menu"
        },
        {
          "when": "game_event:match_ended",
          "goto": "game_over"
        }
      ]
    },
    "game_over": {
      "description": "Match summary",
      "active_systems": [
        "mp_bridge"
      ],
      "on_enter": [
        "show_ui:game_over",
        "show_cursor"
      ],
      "on_exit": [
        "hide_ui:game_over",
        "hide_cursor"
      ],
      "transitions": [
        {
          "when": "ui_event:game_over:play_again",
          "goto": "lobby_room"
        },
        {
          "when": "ui_event:game_over:main_menu",
          "goto": "main_menu"
        }
      ]
    }
  }
}