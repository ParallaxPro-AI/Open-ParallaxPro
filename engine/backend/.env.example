# Server
PORT=3003
NODE_ENV=development

# AI / LLM — any OpenAI-compatible API works (Groq, OpenRouter, local Ollama, etc.)
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=your-api-key-here
AI_MAX_TOKENS=8192

# Game Fixer CLI — install any of `claude`, `codex`, or `opencode` on the
# host. The engine auto-detects them at startup; the editor's Project
# Settings lets you pick which one a given project defaults to.

# Editing-agent Docker sandbox — set to 1 to run every CLI invocation
# inside a container so the agent can only see the per-fix sandbox dir
# and its own auth dir. Requires `docker` on the host plus a pre-built
# image (see engine/backend/docker/agent-sandbox/Dockerfile). Off by
# default; turn it on if you care about file isolation from the agent.
# DOCKER_SANDBOX=1
# DOCKER_SANDBOX_IMAGE=parallaxpro/agent-sandbox:latest

# JWT secret — used for auth tokens (change this to a random string)
JWT_SECRET=dev-secret

# CDN for 3D assets — self-hosted instances without local assets redirect here.
# Default: https://parallaxpro.ai (no change needed unless you host your own assets)
# ASSETS_CDN=https://parallaxpro.ai

# Path to local assets directory (optional — only if you have your own 3D models/audio/textures)
# ASSETS_DIR=/path/to/your/reusable_assets
